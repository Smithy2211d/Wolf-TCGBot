# ────────────────────────────── DISCORD CONFIG ──────────────────────────────

DISCORD_TOKEN=your_discord_bot_token_here

ALERT_CHANNEL_ID=your_discord_channel_id_here

OWNER_ID=your_discord_user_id_here

# Discord server ID for instant slash command registration (optional — omit for global commands)
GUILD_ID=your_guild_id_here

# ────────────────────────────── EULERSTREAM CONFIG ──────────────────────────────

EULER_API_KEY=your_euler_api_key_here

TIKTOK_USERS=username1,username2,username3

# ────────────────────────────── OPTIONAL TUNING ──────────────────────────────

# Max WebSocket reconnect attempts before giving up (default: 4)
MAX_RECONNECT_ATTEMPTS=4

# Cooldown (ms) after offline before a re-live alert is allowed (default: 120000 = 2 min)
FLICKER_COOLDOWN_MS=120000

# Delay (ms) between WebSocket reconnection attempts (default: 90000 = 90s)
RECONNECT_DELAY_MS=90000
